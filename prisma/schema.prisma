generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === IAM ===
model User {
  id                String                @id @default(uuid())
  name              String
  email             String                @unique
  password          String
  role              String                @default("SELLER") // ADMIN, MANAGER, SELLER, TECHNICIAN
  branchId          String?
  branch            Branch?               @relation(fields: [branchId], references: [id])
  sales             Sale[]
  sessions          CashRegisterSession[]
  serviceOrders     ServiceOrder[]
  commissionRecords CommissionRecord[]
}

model Branch {
  id               String                @id @default(uuid())
  code             String                @unique // "LEO", "AV135"
  name             String
  address          String?
  users            User[]
  stocks           Stock[]
  sales            Sale[]
  sessions         CashRegisterSession[]
  serviceOrders    ServiceOrder[]
  customerBikes    CustomerBike[]
  serviceCatalogs  ServiceCatalog[]
  commissionRules  CommissionRule[]
}

// === CATALOG & INVENTORY ===
model Modelo {
  id           String   @id @default(uuid())
  nombre       String   @unique
  descripcion  String?
  requiere_vin Boolean  @default(true)
  imageUrl     String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  coloresDisponibles ModeloColor[]
  configuraciones    ProductVariant[]
  commissionRules    CommissionRule[]
}

model Color {
  id     String @id @default(uuid())
  nombre String @unique

  modelos         ModeloColor[]
  configuraciones ProductVariant[]
}

model Voltaje {
  id    String @id @default(uuid())
  valor Int    @unique
  label String

  configuraciones ProductVariant[]
}

model ModeloColor {
  modelo_id String
  color_id  String
  modelo    Modelo @relation(fields: [modelo_id], references: [id], onDelete: Cascade)
  color     Color  @relation(fields: [color_id], references: [id], onDelete: Cascade)

  @@id([modelo_id, color_id])
}

model ProductVariant {
  id         String  @id @default(uuid())
  modelo_id  String
  color_id   String
  voltaje_id String
  sku        String  @unique
  precioPublico                Decimal  @map("precio") @db.Decimal(10, 2)
  costo                        Decimal  @db.Decimal(10, 2)
  precioDistribuidor           Decimal? @db.Decimal(10, 2)
  precioDistribuidorConfirmado Boolean  @default(false)
  imageUrl   String?

  modelo  Modelo  @relation(fields: [modelo_id], references: [id])
  color   Color   @relation(fields: [color_id], references: [id])
  voltaje Voltaje @relation(fields: [voltaje_id], references: [id])

  stocks             Stock[]
  saleItems          SaleItem[]
  serviceOrderItems  ServiceOrderItem[]
  inventoryMovements InventoryMovement[]

  @@unique([modelo_id, color_id, voltaje_id])
  @@map("ModeloConfiguracion")
}

model Stock {
  id               String         @id @default(uuid())
  productVariantId String         @map("productId")
  branchId         String
  quantity         Int            @default(0)
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  branch           Branch         @relation(fields: [branchId], references: [id])

  @@unique([productVariantId, branchId])
}

enum MovementType {
  SALE
  RETURN
  TRANSFER_OUT
  TRANSFER_IN
  ADJUSTMENT
  PURCHASE_RECEIPT
  WORKSHOP_USAGE
}

model InventoryMovement {
  id               String         @id @default(uuid())
  productVariantId String         @map("productId")
  branchId         String
  quantity         Int
  type             MovementType
  referenceId      String?
  userId           String
  createdAt        DateTime       @default(now())
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
}

// === SALES ===
enum SaleStatus {
  COMPLETED
  CANCELLED
  LAYAWAY
}

model Sale {
  id         String     @id @default(uuid())
  folio      String     @unique
  branchId   String
  userId     String
  customerId String?
  subtotal   Decimal    @db.Decimal(10, 2)
  discount   Decimal    @default(0) @db.Decimal(10, 2)
  total      Decimal    @db.Decimal(10, 2)
  status     SaleStatus
  notes        String?
  internalNote String?  // Visible para MANAGER; no aparece en el ticket del cliente
  createdAt    DateTime @default(now())

  branch            Branch             @relation(fields: [branchId], references: [id])
  user              User               @relation(fields: [userId], references: [id])
  customer          Customer?          @relation(fields: [customerId], references: [id])
  items             SaleItem[]
  payments          CashTransaction[]
  commissionRecords CommissionRecord[]
}

model SaleItem {
  id               String         @id @default(uuid())
  saleId           String
  productVariantId String         @map("productId")
  quantity         Int
  price            Decimal        @db.Decimal(10, 2)
  discount         Decimal        @default(0) @db.Decimal(10, 2)
  sale             Sale           @relation(fields: [saleId], references: [id])
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
}

// === PAYMENTS & CASHIER ===
enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  CREDIT_BALANCE
  ATRATO // Financiera externa; el cobro queda PENDING hasta que transfieren
}

enum CollectionStatus {
  COLLECTED // Dinero ya recibido (default)
  PENDING   // Pago pendiente de liquidación por la financiera (ej. Atrato)
}

model CashRegisterSession {
  id         String    @id @default(uuid())
  branchId   String
  userId     String
  openedAt   DateTime  @default(now())
  closedAt   DateTime?
  openingAmt Decimal   @db.Decimal(10, 2)
  closingAmt Decimal?  @db.Decimal(10, 2)
  status     String    @default("OPEN") // OPEN, CLOSED

  branch       Branch            @relation(fields: [branchId], references: [id])
  user         User              @relation(fields: [userId], references: [id])
  transactions CashTransaction[]
}

model CashTransaction {
  id               String           @id @default(uuid())
  sessionId        String
  saleId           String?
  type             String           // PAYMENT_IN, REFUND_OUT, EXPENSE_OUT, WITHDRAWAL
  method           PaymentMethod
  amount           Decimal          @db.Decimal(10, 2)
  collectionStatus CollectionStatus @default(COLLECTED)
  createdAt        DateTime         @default(now())

  session CashRegisterSession @relation(fields: [sessionId], references: [id])
  sale    Sale?               @relation(fields: [saleId], references: [id])
}

// === CRM ===
model Customer {
  id            String         @id @default(uuid())
  name          String
  phone         String?        @unique
  email         String?
  creditLimit   Decimal        @default(0) @db.Decimal(10, 2)
  balance       Decimal        @default(0) @db.Decimal(10, 2)
  sales         Sale[]
  serviceOrders ServiceOrder[]
  bikes         CustomerBike[]
}

model CustomerBike {
  id           String   @id @default(uuid())
  customerId   String
  branchId     String
  serialNumber String
  brand        String?
  model        String?
  color        String?
  notes        String?
  createdAt    DateTime @default(now())

  customer      Customer       @relation(fields: [customerId], references: [id])
  branch        Branch         @relation(fields: [branchId], references: [id])
  serviceOrders ServiceOrder[]

  @@unique([serialNumber, branchId])
}

// === WORKSHOP (TALLER) ===
enum ServiceOrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DELIVERED
  CANCELLED
}

model ServiceOrder {
  id             String             @id @default(uuid())
  folio          String             @unique
  branchId       String
  userId         String // Technician or Seller who registered it
  customerId     String
  customerBikeId String?
  bikeInfo       String? // Ej. "Trek Marlin 5 Roja 2021"
  diagnosis      String?
  subtotal       Decimal            @default(0) @db.Decimal(10, 2)
  total          Decimal            @default(0) @db.Decimal(10, 2)
  status         ServiceOrderStatus @default(PENDING)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  branch       Branch             @relation(fields: [branchId], references: [id])
  user         User               @relation(fields: [userId], references: [id])
  customer     Customer           @relation(fields: [customerId], references: [id])
  customerBike CustomerBike?      @relation(fields: [customerBikeId], references: [id])
  items        ServiceOrderItem[]
}

model ServiceOrderItem {
  id               String          @id @default(uuid())
  serviceOrderId   String
  productVariantId String?         @map("productId")
  serviceCatalogId String?
  description      String
  quantity         Int             @default(1)
  price            Decimal         @db.Decimal(10, 2)

  serviceOrder   ServiceOrder    @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  productVariant ProductVariant? @relation(fields: [productVariantId], references: [id])
  serviceCatalog ServiceCatalog? @relation(fields: [serviceCatalogId], references: [id])
}

// === COMMISSIONS ===
enum CommissionType {
  PERCENTAGE   // Porcentaje sobre el total de la venta (ej. 3.5%)
  FIXED_AMOUNT // Monto fijo por venta (ej. $50 MXN)
}

enum CommissionStatus {
  PENDING  // Comisión generada, pendiente de revisión
  APPROVED // Aprobada por gerente, lista para pagar
  PAID     // Pagada al vendedor
}

model CommissionRule {
  id             String         @id @default(uuid())
  role           String         // ADMIN | MANAGER | SELLER | TECHNICIAN
  commissionType CommissionType
  value          Decimal        @db.Decimal(10, 4) // Porcentaje (0-100) o monto fijo
  modeloId       String?        // null = aplica a todos los modelos
  isActive       Boolean        @default(true)
  branchId       String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  branch  Branch             @relation(fields: [branchId], references: [id])
  modelo  Modelo?            @relation(fields: [modeloId], references: [id])
  records CommissionRecord[]
}

model CommissionRecord {
  id        String           @id @default(uuid())
  saleId    String
  userId    String
  ruleId    String
  amount    Decimal          @db.Decimal(10, 2) // Monto calculado al momento de la venta
  status    CommissionStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  sale Sale           @relation(fields: [saleId], references: [id])
  user User           @relation(fields: [userId], references: [id])
  rule CommissionRule @relation(fields: [ruleId], references: [id])
}

// === SERVICE CATALOG ===
model ServiceCatalog {
  id        String   @id @default(uuid())
  name      String
  basePrice Decimal  @db.Decimal(10, 2)
  isActive  Boolean  @default(true)
  branchId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  branch            Branch             @relation(fields: [branchId], references: [id])
  serviceOrderItems ServiceOrderItem[]
}
