generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// === IAM ===
model User {
  id                String                @id @default(uuid())
  name              String
  email             String                @unique
  password          String
  pin               String? // hash bcrypt del PIN corto (solo MANAGER/ADMIN). Validado vs. AuthorizationRequest.
  role              String                @default("SELLER") // ADMIN, MANAGER, SELLER, TECHNICIAN
  isActive          Boolean               @default(true)
  branchId          String?
  branch            Branch?               @relation(fields: [branchId], references: [id])
  sales             Sale[]
  sessions          CashRegisterSession[]
  serviceOrders     ServiceOrder[]
  commissionRecords CommissionRecord[]

  batteryLots          BatteryLot[]
  batteryAssignments   BatteryAssignment[] @relation("AssignedBy")
  batteryUnassignments BatteryAssignment[] @relation("UnassignedBy")
  assemblyOrders       AssemblyOrder[]     @relation("AssemblyOrders")

  quotationsCreated      Quotation[] @relation("QuotationCreator")
  quotationsDiscountAuth Quotation[] @relation("QuotationDiscountAuth")
  quotationsConverted    Quotation[] @relation("QuotationConverter")

  purchaseReceipts PurchaseReceipt[]

  authorizationsRequested AuthorizationRequest[] @relation("AuthRequester")
  authorizationsApproved  AuthorizationRequest[] @relation("AuthApprover")

  authorizedCashSessions CashRegisterSession[] @relation("CashSessionAuthorizer")
  cashTransactions       CashTransaction[]

  operationalExpensesRegistered OperationalExpense[]  @relation("OperationalExpenseRegistradoPor")
  operationalExpensesAnulled    OperationalExpense[]  @relation("OperationalExpenseAnuladoPor")
  bankBalanceSnapshots          BankBalanceSnapshot[] @relation("BankBalanceSnapshotRegistradoPor")

  transfersCreadas     StockTransfer[] @relation("TransferCreada")
  transfersAutorizadas StockTransfer[] @relation("TransferAutorizada")
  transfersDespachadas StockTransfer[] @relation("TransferDespachada")
  transfersRecibidas   StockTransfer[] @relation("TransferRecibida")
  transfersCanceladas  StockTransfer[] @relation("TransferCancelada")

  // Workshop redesign (Sub-fase A). `serviceOrders` (arriba, default relation) = quien la registró.
  serviceOrdersAssigned        ServiceOrder[]         @relation("ServiceOrderAssignedTech")
  serviceOrdersServiced        ServiceOrder[]         @relation("ServiceOrderServicedBy")
  serviceOrdersQaPassed        ServiceOrder[]         @relation("ServiceOrderQaPassedBy")
  serviceOrderApprovalsCreated ServiceOrderApproval[]

  // === Reportes v1 ===
  pinnedReports String[] @default([]) // slugs; UI garantiza max 4
  uiPreferences Json? // tweaks del panel de reportes (densidad, layouts, etc.)

  // Customers redesign (Sub-fase A)
  customerNotes    CustomerNote[]
  customerEditLogs CustomerEditLog[]

  // WhatsApp outbox
  waMessagesOpened   OutboundMessage[]  @relation("WaMessageOpenedBy")
  waTemplatesUpdated WhatsAppTemplate[] @relation("WaTemplateUpdatedBy")
}

model Branch {
  id                       String                @id @default(uuid())
  code                     String                @unique // "LEO", "AV135"
  name                     String
  address                  String? // legacy — se conserva; nuevos campos desglosados abajo
  rfc                      String?
  razonSocial              String?
  regimenFiscal            String?
  street                   String?
  extNum                   String?
  intNum                   String?
  colonia                  String?
  city                     String?
  state                    String?
  zip                      String?
  phone                    String?
  email                    String?
  website                  String?
  sealImageUrl             String?
  terminosCotizacion       String?               @db.Text
  terminosPedido           String?               @db.Text
  terminosPoliza           String?               @db.Text
  terminosServicio         String?               @db.Text
  lastSaleFolioNumber      Int                   @default(0)
  lastQuotationFolioNumber Int                   @default(0)
  users                    User[]
  stocks                   Stock[]
  sales                    Sale[]
  sessions                 CashRegisterSession[]
  serviceOrders            ServiceOrder[]
  customerBikes            CustomerBike[]
  serviceCatalogs          ServiceCatalog[]
  commissionRules          CommissionRule[]

  batteryLots    BatteryLot[]
  batteries      Battery[]
  assemblyOrders AssemblyOrder[]

  quotations          Quotation[] @relation("QuotationBranch")
  quotationsConverted Quotation[] @relation("QuotationConvertedInBranch")

  purchaseReceipts      PurchaseReceipt[]
  authorizationRequests AuthorizationRequest[]
  operationalExpenses   OperationalExpense[]

  transferenciasEnviadas  StockTransfer[] @relation("TransferenciasSalientes")
  transferenciasRecibidas StockTransfer[] @relation("TransferenciasEntrantes")

  // Workshop redesign (Sub-fase A)
  hourlyRate             Decimal? @db.Decimal(10, 2)
  whatsappTemplateTaller String?

  // Workshop redesign (Sub-fase D.1) — second-checker opcional para QA.
  // Cuando true, /deliver rechaza si servicedByUserId == qaPassedByUserId.
  requireQaSecondChecker Boolean @default(false)

  alertThresholds AlertThreshold[]
}

// === CATALOG & INVENTORY ===
enum ModeloCategoria {
  BICICLETA // deprecated — backfilled a BASE/PLUS; se mantiene para no romper enum
  TRICICLO
  SCOOTER
  JUGUETE
  CARGA
  CARGA_PESADA
  BASE
  PLUS
}

model Modelo {
  id           String           @id @default(uuid())
  nombre       String           @unique
  descripcion  String?
  requiere_vin Boolean          @default(true)
  imageUrl     String?
  categoria    ModeloCategoria? // null = Modelo de batería. Vehículos: una de las 7 categorías.
  esBateria    Boolean          @default(false)
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  coloresDisponibles ModeloColor[]
  configuraciones    ProductVariant[]
  commissionRules    CommissionRule[]

  batteryConfigurations BatteryConfiguration[]
  warrantyDays          Int? // NULL = sin póliza. Solo aplica si requiere_vin = true (CHECK en migration.sql)

  warrantyPolicies WarrantyPolicy[]
}

model Color {
  id        String  @id @default(uuid())
  nombre    String  @unique
  isGeneric Boolean @default(false)
  isActive  Boolean @default(true)

  modelos         ModeloColor[]
  configuraciones ProductVariant[]
}

model Voltaje {
  id       String  @id @default(uuid())
  valor    Int     @unique
  label    String
  isActive Boolean @default(true)

  configuraciones ProductVariant[]

  batteryConfigurations BatteryConfiguration[]
}

// Eje de capacidad (Ah) — solo relevante para variantes de batería.
// Variantes de vehículo tienen capacidadId = null.
model Capacidad {
  id       String  @id @default(uuid())
  valorAh  Float   @unique
  nombre   String // p. ej. "20Ah", "20.8Ah"
  isActive Boolean @default(true)

  configuraciones ProductVariant[]
}

model ModeloColor {
  modelo_id String
  color_id  String
  modelo    Modelo @relation(fields: [modelo_id], references: [id], onDelete: Cascade)
  color     Color  @relation(fields: [color_id], references: [id], onDelete: Cascade)

  @@id([modelo_id, color_id])
}

model ProductVariant {
  id                           String   @id @default(uuid())
  modelo_id                    String
  color_id                     String
  voltaje_id                   String
  capacidad_id                 String? // null en variantes de vehículo; set en variantes de batería
  sku                          String   @unique
  precioPublico                Decimal  @map("precio") @db.Decimal(10, 2)
  costo                        Decimal  @db.Decimal(10, 2)
  precioDistribuidor           Decimal? @db.Decimal(10, 2)
  precioDistribuidorConfirmado Boolean  @default(false)
  stockMinimo                  Int      @default(0)
  stockMaximo                  Int      @default(0)
  imageUrl                     String?
  isActive                     Boolean  @default(true)

  modelo    Modelo     @relation(fields: [modelo_id], references: [id])
  color     Color      @relation(fields: [color_id], references: [id])
  voltaje   Voltaje    @relation(fields: [voltaje_id], references: [id])
  capacidad Capacidad? @relation(fields: [capacidad_id], references: [id])

  stocks             Stock[]
  saleItems          SaleItem[]
  serviceOrderItems  ServiceOrderItem[]
  inventoryMovements InventoryMovement[]

  batteryLots        BatteryLot[]
  batteryConfigs     BatteryConfiguration[] @relation("ConfiguredBattery")
  assemblyOrders     AssemblyOrder[]
  customerBikes      CustomerBike[]
  quotationItems     QuotationItem[]
  stockTransferItems StockTransferItem[]

  // Postgres trata NULL como distinto: variantes de vehículo (capacidad_id=null) coexisten con baterías (capacidad_id set).
  @@unique([modelo_id, color_id, voltaje_id, capacidad_id])
  @@map("ModeloConfiguracion")
}

model Stock {
  id               String          @id @default(uuid())
  productVariantId String?         @map("productId")
  simpleProductId  String?
  branchId         String
  quantity         Int             @default(0)
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id])
  simpleProduct    SimpleProduct?  @relation(fields: [simpleProductId], references: [id])
  branch           Branch          @relation(fields: [branchId], references: [id])

  // Polimorfismo: exactamente uno de (productVariantId, simpleProductId) por fila (CHECK en SQL).
  // Postgres trata NULL como distinto en UNIQUE, así los dos @@unique coexisten sin colisión.
  @@unique([productVariantId, branchId])
  @@unique([simpleProductId, branchId])
}

enum MovementType {
  SALE
  RETURN
  TRANSFER_OUT
  TRANSFER_IN
  ADJUSTMENT
  PURCHASE_RECEIPT
  WORKSHOP_USAGE
}

model InventoryMovement {
  id                   String           @id @default(uuid())
  productVariantId     String?          @map("productId")
  simpleProductId      String?
  branchId             String
  quantity             Int
  type                 MovementType
  referenceId          String?
  userId               String
  // Solo aplica a movimientos tipo PURCHASE_RECEIPT. Invariante documentada en AGENTS.md,
  // no aplicada con CHECK: SALE/RETURN/TRANSFER/ADJUSTMENT/WORKSHOP_USAGE siempre nulo.
  purchaseReceiptId    String?
  precioUnitarioPagado Decimal?         @db.Decimal(10, 2)
  createdAt            DateTime         @default(now())
  productVariant       ProductVariant?  @relation(fields: [productVariantId], references: [id])
  simpleProduct        SimpleProduct?   @relation(fields: [simpleProductId], references: [id])
  purchaseReceipt      PurchaseReceipt? @relation(fields: [purchaseReceiptId], references: [id])
}

// === SALES ===
enum SaleType {
  DIRECT
  LAYAWAY
  BACKORDER
  SERVICE
}

enum OrderType {
  LAYAWAY
  BACKORDER
}

enum SaleStatus {
  COMPLETED
  CANCELLED
  LAYAWAY
}

model Sale {
  id                   String        @id @default(uuid())
  folio                String        @unique
  branchId             String
  userId               String
  customerId           String?
  subtotal             Decimal       @db.Decimal(10, 2)
  discount             Decimal       @default(0) @db.Decimal(10, 2)
  total                Decimal       @db.Decimal(10, 2)
  status               SaleStatus
  notes                String?
  internalNote         String? // Visible para MANAGER; no aparece en el ticket del cliente
  orderType            OrderType?
  // Invariante Sale.type (sin CHECK constraint; garantizado por sale.create callers + seed):
  //   serviceOrderId != null  → type = SERVICE,  orderType = null
  //   orderType != null       → type ∈ {LAYAWAY, BACKORDER} (match orderType)
  //   else                    → type = DIRECT,   orderType = null
  // orderType se conserva por compat (15 archivos lo consumen); eliminarlo es deuda de Fase 6.
  // excludeFromRevenue filtra ventas sin ingreso real (WARRANTY/COURTESY/POLICY_MAINTENANCE) de
  // los KPIs de reportes. No afecta ingresoTotal (total=0) — sí numVentas y ticketPromedio.
  type                 SaleType      @default(DIRECT)
  excludeFromRevenue   Boolean       @default(false)
  expectedDeliveryDate DateTime?
  quotationId          String?       @unique // cotización que originó esta venta (sin FK, set manual)
  serviceOrderId       String?       @unique
  serviceOrder         ServiceOrder? @relation(fields: [serviceOrderId], references: [id])
  warrantyDocReady     Boolean       @default(true)
  createdAt            DateTime      @default(now())

  branch                Branch                 @relation(fields: [branchId], references: [id])
  user                  User                   @relation(fields: [userId], references: [id])
  customer              Customer?              @relation(fields: [customerId], references: [id])
  items                 SaleItem[]
  payments              CashTransaction[]
  commissionRecords     CommissionRecord[]
  assemblyOrders        AssemblyOrder[]
  quotation             Quotation?             @relation("QuotationConvertedSale")
  authorizationRequests AuthorizationRequest[]
  warrantyPolicies      WarrantyPolicy[]
}

model SaleItem {
  id               String          @id @default(uuid())
  saleId           String
  productVariantId String?         @map("productId") // nullable: líneas libres (cotización → venta)
  simpleProductId  String?
  description      String? // snapshot del nombre del producto o descripción libre
  isFreeForm       Boolean         @default(false) // true = línea libre sin producto del catálogo
  quantity         Int
  price            Decimal         @db.Decimal(10, 2)
  discount         Decimal         @default(0) @db.Decimal(10, 2)
  sale             Sale            @relation(fields: [saleId], references: [id])
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id])
  simpleProduct    SimpleProduct?  @relation(fields: [simpleProductId], references: [id])
  batteryLots      BatteryLot[]
  warrantyPolicies WarrantyPolicy[]
}

// === PAYMENTS & CASHIER ===
enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  CREDIT_BALANCE
  ATRATO // Financiera externa; el cobro queda PENDING hasta que transfieren
}

enum CollectionStatus {
  COLLECTED // Dinero ya recibido (default)
  PENDING // Pago pendiente de liquidación por la financiera (ej. Atrato)
  REJECTED // Atrato rechazó solicitud post-aprobación inicial (Pack C.1 Q5 INT-2)
  DEFAULTED // Atrato no pudo cobrar al cliente final (Pack C.1 Q5 INT-2)
  CANCELLED // Contrato Atrato cancelado (devolución vía Atrato — decision A.2 #5 2026-04-30)
}

enum CashTransactionType {
  PAYMENT_IN
  REFUND_OUT
  EXPENSE_OUT
  WITHDRAWAL
  CASH_DEPOSIT // Entrada manual de efectivo (dotación de cambio, reposición de fondo)
}

enum CashExpenseCategory {
  MENSAJERIA
  PAPELERIA
  CONSUMO
  MANTENIMIENTO
  PAGO_PROVEEDOR
  LIMPIEZA
  AJUSTE_CAJA
  OTRO
}

enum CashDepositCategory {
  DOTACION_INICIAL
  CAMBIO
  OTROS
}

model CashRegisterSession {
  id                String    @id @default(uuid())
  branchId          String
  userId            String
  openedAt          DateTime  @default(now())
  closedAt          DateTime?
  // Efectivo exclusivamente. Tarjeta/transferencia no aplican.
  openingAmt        Decimal   @db.Decimal(10, 2)
  closingAmt        Decimal?  @db.Decimal(10, 2)
  diferencia        Decimal?  @db.Decimal(10, 2) // closingAmt - expectedAmt calculado server-side al cerrar; null mientras status = OPEN
  authorizedById    String? // User que autorizó el cierre con diferencia (MANAGER/ADMIN). null si diferencia = 0 o SELLER sin diferencia.
  status            String    @default("OPEN") // OPEN, CLOSED
  denominationsJson Json? // Desglose de billetes contados al cierre: { "1000": 2, "500": 3, ... }. null en sesiones legacy.

  branch             Branch                @relation(fields: [branchId], references: [id])
  user               User                  @relation(fields: [userId], references: [id])
  authorizedBy       User?                 @relation("CashSessionAuthorizer", fields: [authorizedById], references: [id])
  transactions       CashTransaction[]
  closeAuthorization AuthorizationRequest? @relation("SessionCloseAuth")
}

model CashTransaction {
  id               String               @id @default(uuid())
  sessionId        String
  saleId           String?
  userId           String? // Usuario que registró el movimiento. Nullable por backfill histórico.
  customerId       String? // FK a Customer (timeline del perfil). Nullable: recargas standalone sin vínculo a Sale quedan null.
  type             CashTransactionType
  method           PaymentMethod
  amount           Decimal              @db.Decimal(10, 2)
  reference        String? // WITHDRAWAL: número de sobre. PAYMENT_IN: referencia opcional de pago.
  beneficiary      String? // EXPENSE_OUT: nombre/razón social del destinatario (cuando NO es Supplier registrado)
  supplierId       String? // FK a Supplier — Pack D.bis. Cualquier expenseCategory puede linkear; refinement a PAGO_PROVEEDOR DROPADO (cliente listó CFE/Telmex/etc en categorías SERVICIOS_PUBLICOS/RENTA/MARKETING)
  notes            String? // Motivo o concepto libre (obligatorio en EXPENSE_OUT, opcional en otros)
  collectionStatus CollectionStatus     @default(COLLECTED)
  collectedAt      DateTime? // Fecha en que el dinero quedó efectivamente en caja; null mientras collectionStatus = PENDING
  expenseCategory  CashExpenseCategory? // Solo se pobla cuando type = EXPENSE_OUT
  depositCategory  CashDepositCategory? // Solo se pobla cuando type = CASH_DEPOSIT
  createdAt        DateTime             @default(now())

  session  CashRegisterSession @relation(fields: [sessionId], references: [id])
  sale     Sale?               @relation(fields: [saleId], references: [id])
  user     User?               @relation(fields: [userId], references: [id])
  customer Customer?           @relation(fields: [customerId], references: [id])
  supplier Supplier?           @relation(fields: [supplierId], references: [id])

  creditConsumptions CreditConsumption[] // Pack D.1 — consumos/re-acreditaciones de saldo a favor

  @@index([customerId])
  @@index([supplierId]) // Pack D.bis — estado de cuenta GASTO por supplier
}

// === CRM ===
model Customer {
  id             String  @id @default(uuid())
  name           String
  // Derivado de `name`: minúsculas + sin acentos. Poblado en create/update
  // para permitir búsqueda tolerante ("jose" matchea "José"). Indexado.
  nameNormalized String  @default("")
  phone          String?
  phone2         String?
  email          String?
  creditLimit    Decimal @default(0) @db.Decimal(10, 2)

  // Dirección para flete (todos opcionales)
  shippingStreet  String?
  shippingExtNum  String?
  shippingIntNum  String?
  shippingColonia String?
  shippingCity    String?
  shippingState   String?
  shippingZip     String?
  shippingRefs    String?

  // Datos de facturación (todos opcionales)
  rfc             String? @unique
  razonSocial     String?
  regimenFiscal   String?
  usoCFDI         String?
  emailFiscal     String?
  // Dirección fiscal desglosada (los nuevos formularios escriben aquí).
  fiscalStreet    String?
  fiscalExtNum    String?
  fiscalIntNum    String?
  fiscalColonia   String?
  fiscalCity      String?
  fiscalState     String?
  fiscalZip       String?
  // Legacy: dirección fiscal en un único string. Se conserva para no perder
  // datos capturados antes de la migración a campos desglosados. Los
  // endpoints ya no escriben aquí; lectura fallback para registros antiguos.
  direccionFiscal String?

  // === Identidad / INE ===
  curp          String?
  ineScanUrl    String? // URL en R2
  ineCapturedAt DateTime?

  // === Customers redesign — Sub-fase A ===
  birthday             DateTime?
  isBusiness           Boolean               @default(false)
  communicationConsent Boolean               @default(false)
  tags                 String[]              @default([])
  phonePrevious        String? // soft-save del teléfono anterior antes de sobrescribir
  mergedIntoId         String? // FK a Customer — target de fusión (soft-merge)
  mergedAt             DateTime?
  deletedAt            DateTime?
  deletedReason        CustomerDeleteReason?

  sales            Sale[]
  serviceOrders    ServiceOrder[]
  bikes            CustomerBike[]
  quotations       Quotation[]
  cashTransactions CashTransaction[]

  // Soft-merge self-relation
  mergedInto    Customer?  @relation("CustomerMerge", fields: [mergedIntoId], references: [id])
  mergedSources Customer[] @relation("CustomerMerge")

  notes    CustomerNote[]
  editLogs CustomerEditLog[]

  customerCredits CustomerCredit[] // Pack D.1 — saldo a favor granular (reemplaza Customer.balance)

  outboundMessages OutboundMessage[]

  @@index([mergedIntoId])
  @@index([deletedAt])
  @@index([phone])
  @@index([email])
  @@index([nameNormalized])
}

enum CustomerDeleteReason {
  DUPLICATE
  REQUEST
  ERROR
}

model CustomerBike {
  id               String   @id @default(uuid())
  customerId       String?
  branchId         String
  productVariantId String?
  serialNumber     String
  brand            String?
  model            String?
  color            String?
  voltaje          String?
  odometerKm       Int? // Kilometraje capturado en recepción o editable desde perfil
  notes            String?
  createdAt        DateTime @default(now())

  customer       Customer?          @relation(fields: [customerId], references: [id])
  branch         Branch             @relation(fields: [branchId], references: [id])
  productVariant ProductVariant?    @relation(fields: [productVariantId], references: [id])
  serviceOrders  ServiceOrder[]
  voltageChanges VoltageChangeLog[]

  batteryAssignments BatteryAssignment[]
  assemblyOrders     AssemblyOrder[]
  stockTransferItems StockTransferItem[]
  editLogs           CustomerEditLog[]
  warrantyPolicies   WarrantyPolicy[]

  @@unique([serialNumber, branchId])
}

// === Customers redesign — Sub-fase A ===
model CustomerNote {
  id         String           @id @default(cuid())
  customerId String
  customer   Customer         @relation(fields: [customerId], references: [id])
  authorId   String
  author     User             @relation(fields: [authorId], references: [id])
  kind       CustomerNoteKind
  body       String
  pinned     Boolean          @default(false)
  createdAt  DateTime         @default(now())

  @@index([customerId, createdAt(sort: Desc)])
}

enum CustomerNoteKind {
  NOTE
  PHONE_CALL
  WHATSAPP_SENT
  EMAIL_SENT
}

model CustomerEditLog {
  id             String        @id @default(cuid())
  customerId     String
  customer       Customer      @relation(fields: [customerId], references: [id])
  customerBikeId String? // opcional — para ediciones sobre CustomerBike (ej. odómetro)
  customerBike   CustomerBike? @relation(fields: [customerBikeId], references: [id])
  userId         String
  user           User          @relation(fields: [userId], references: [id])
  field          String // "rfc" | "creditLimit" | "razonSocial" | "phone" | "odometerKm" | ...
  oldValue       String?
  newValue       String?
  reason         String? // motivo capturado en diálogos de confirmación
  createdAt      DateTime      @default(now())

  @@index([customerId, createdAt(sort: Desc)])
  @@index([customerBikeId, field])
}

// === CUSTOMER CREDIT (saldo a favor — Pack D.1) ===

enum OrigenCredito {
  CANCELACION
  APARTADO_CANCELADO
  DEVOLUCION
  AJUSTE_MANAGER
  RECARGA_CLIENTE // depósito en efectivo/tarjeta/transferencia hecho por el propio cliente
  MIGRACION_INICIAL // backfill de Customer.balance legacy en Pack D.1 Migration 2
}

enum JobStatus {
  RUNNING
  OK
  FAILED
  PARTIAL // algunos rows OK, otros fallaron — visible en reporte de salud
}

model CustomerCredit {
  id          String        @id @default(uuid())
  customerId  String
  monto       Decimal       @db.Decimal(10, 2)
  balance     Decimal       @db.Decimal(10, 2) // CHECK >= 0 AND <= monto (raw SQL post-migration)
  origenTipo  OrigenCredito
  origenId    String? // saleId | quotationId | returnId | adjustmentId | NULL
  notes       String?
  createdAt   DateTime      @default(now()) @db.Timestamptz(3)
  expiresAt   DateTime      @db.Timestamptz(3) // = createdAt + 365d (set por helper)
  expiredAt   DateTime?     @db.Timestamptz(3) // llenado por cron P6 cuando now() > expiresAt
  alertSentAt DateTime?     @db.Timestamptz(3) // llenado por cron alerta 90d (P6)

  customer     Customer            @relation(fields: [customerId], references: [id])
  consumptions CreditConsumption[]

  @@index([customerId, expiredAt, balance]) // golden path "créditos activos del cliente" + banner POS FIFO
}

model CreditConsumption {
  id                String   @id @default(uuid())
  customerCreditId  String
  cashTransactionId String
  amount            Decimal  @db.Decimal(10, 2) // positivo = consumo, negativo = re-acreditación (Edge A/A.1)
  createdAt         DateTime @default(now()) @db.Timestamptz(3)

  customerCredit  CustomerCredit  @relation(fields: [customerCreditId], references: [id])
  cashTransaction CashTransaction @relation(fields: [cashTransactionId], references: [id])

  @@index([customerCreditId])
  @@index([cashTransactionId]) // reverso en cancel/return — buscar consumos a re-acreditar
}

model JobRun {
  id             String    @id @default(uuid())
  jobName        String
  status         JobStatus
  startedAt      DateTime  @default(now()) @db.Timestamptz(3)
  finishedAt     DateTime? @db.Timestamptz(3)
  durationMs     Int?
  processedCount Int       @default(0) // # rows touched (alerta enviada, crédito vencido, etc.)
  errorCount     Int       @default(0) // # rows que fallaron dentro del run
  errorMessage   String? // última excepción (resumen)

  @@index([jobName, startedAt(sort: Desc)]) // últimas N corridas por job
}

// === WORKSHOP (TALLER) ===
enum ServiceOrderStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  DELIVERED
  CANCELLED
}

// Workshop redesign (Sub-fase A) — enums nuevos
enum ChargeModel {
  FIXED
  HOURLY
}

enum ServiceOrderType {
  PAID
  WARRANTY
  COURTESY
  POLICY_MAINTENANCE
}

enum ServiceOrderSubStatus {
  WAITING_PARTS
  WAITING_APPROVAL
  PAUSED
}

enum ServiceOrderApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ServiceOrderApprovalChannel {
  WHATSAPP_PUBLIC
  PHONE_CALL
  IN_PERSON
  OTHER
}

model ServiceOrder {
  id             String             @id @default(uuid())
  folio          String             @unique
  branchId       String
  userId         String // Technician or Seller who registered it
  customerId     String
  customerBikeId String?
  bikeInfo       String? // Ej. "Trek Marlin 5 Roja 2021"
  diagnosis      String?
  subtotal       Decimal            @default(0) @db.Decimal(10, 2)
  total          Decimal            @default(0) @db.Decimal(10, 2)
  status         ServiceOrderStatus @default(PENDING)
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  branch        Branch             @relation(fields: [branchId], references: [id])
  user          User               @relation(fields: [userId], references: [id])
  customer      Customer           @relation(fields: [customerId], references: [id])
  customerBike  CustomerBike?      @relation(fields: [customerBikeId], references: [id])
  items         ServiceOrderItem[]
  sale          Sale?
  prepaid       Boolean            @default(false)
  // Hotfix (2026-04-22) — aditivo, NULL para órdenes existentes con
  // prepaid=true. Poblado por /charge + backfill script one-shot.
  // Pack E.7 (2026-05-02) — prepaidMethod dropeado. Consumers derivan
  // ahora desde Sale.payments[] vía derivePrepaidMethodFromPayments
  // (lib/workshop-prepaid.ts).
  prepaidAt     DateTime?
  prepaidAmount Decimal?           @db.Decimal(10, 2)

  // Workshop redesign (Sub-fase A) — aditivo, todos nullable o con default
  assignedTechId     String?
  assignedTech       User?                  @relation("ServiceOrderAssignedTech", fields: [assignedTechId], references: [id])
  servicedByUserId   String?
  servicedByUser     User?                  @relation("ServiceOrderServicedBy", fields: [servicedByUserId], references: [id])
  type               ServiceOrderType       @default(PAID)
  subStatus          ServiceOrderSubStatus? // solo relevante mientras status = IN_PROGRESS
  qaPassedAt         DateTime?
  qaPassedByUserId   String?
  qaPassedByUser     User?                  @relation("ServiceOrderQaPassedBy", fields: [qaPassedByUserId], references: [id])
  qaNotes            String?
  publicToken        String?                @unique
  publicTokenEnabled Boolean                @default(true)
  approvals          ServiceOrderApproval[]

  // WARRANTY flow (Pack G.1 INT-4)
  ineCustomerSnapshotJson Json? // { nombre, curp, fechaCaptura, ineScanHash } — solo type=WARRANTY al aceptar
  partRequestedAt         DateTime? // set al transicionar a WAITING_PARTS (primer pedido; NULL-guard)
  partReceivedAt          DateTime? // set al salir de WAITING_PARTS → IN_PROGRESS

  // Workshop redesign (Sub-fase C — Recepción)
  checklist            Json? // [{key, state: "OK"|"FAIL"|"NA", note?}]
  signatureData        String? // base64 PNG (data URL); null si rechazada
  signatureRejected    Boolean @default(false)
  photoUrls            Json? // string[] — rutas a /public/workshop/...
  expectedDeliveryDate String? // "YYYY-MM-DD" — NO DateTime (patrón fechaVencimiento)

  @@index([branchId, status])
  @@index([assignedTechId])
  @@index([servicedByUserId])
  @@index([status, subStatus])
}

model ServiceOrderItem {
  id               String  @id @default(uuid())
  serviceOrderId   String
  productVariantId String? @map("productId")
  simpleProductId  String?
  serviceCatalogId String?
  description      String
  quantity         Int     @default(1)
  price            Decimal @db.Decimal(10, 2)

  inventoryMovementId String?         @unique
  serviceOrder        ServiceOrder    @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  productVariant      ProductVariant? @relation(fields: [productVariantId], references: [id])
  simpleProduct       SimpleProduct?  @relation(fields: [simpleProductId], references: [id])
  serviceCatalog      ServiceCatalog? @relation(fields: [serviceCatalogId], references: [id])

  // Workshop redesign (Sub-fase A)
  laborMinutes Int? // solo cuando serviceCatalog.chargeModel = HOURLY
  isExtra      Boolean  @default(false) // true = agregado post-diagnóstico (requiere approval)
  createdAt    DateTime @default(now())
}

// === COMMISSIONS ===
enum CommissionType {
  PERCENTAGE // Porcentaje sobre el total de la venta (ej. 3.5%)
  FIXED_AMOUNT // Monto fijo por venta (ej. $50 MXN)
}

enum CommissionStatus {
  PENDING // Comisión generada, pendiente de revisión
  APPROVED // Aprobada por gerente, lista para pagar
  PAID // Pagada al vendedor
  CANCELLED // Comisión anulada por cancelación de la venta asociada
}

model CommissionRule {
  id             String         @id @default(uuid())
  role           String // ADMIN | MANAGER | SELLER | TECHNICIAN
  commissionType CommissionType
  value          Decimal        @db.Decimal(10, 4) // Porcentaje (0-100) o monto fijo
  modeloId       String? // null = aplica a todos los modelos
  isActive       Boolean        @default(true)
  branchId       String
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  branch  Branch             @relation(fields: [branchId], references: [id])
  modelo  Modelo?            @relation(fields: [modeloId], references: [id])
  records CommissionRecord[]
}

model CommissionRecord {
  id        String           @id @default(uuid())
  saleId    String
  userId    String
  ruleId    String
  amount    Decimal          @db.Decimal(10, 2) // Monto calculado al momento de la venta
  status    CommissionStatus @default(PENDING)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt

  sale Sale           @relation(fields: [saleId], references: [id])
  user User           @relation(fields: [userId], references: [id])
  rule CommissionRule @relation(fields: [ruleId], references: [id])
}

// === SERVICE CATALOG ===
model ServiceCatalog {
  id              String   @id @default(uuid())
  name            String
  basePrice       Decimal  @db.Decimal(10, 2)
  isActive        Boolean  @default(true)
  esMantenimiento Boolean  @default(false)
  branchId        String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Workshop redesign (Sub-fase A) — mano de obra mixta (decisión #3 BRIEF)
  chargeModel      ChargeModel @default(FIXED)
  estimatedMinutes Int? // informativo en FIXED; base de cálculo en HOURLY

  branch            Branch             @relation(fields: [branchId], references: [id])
  serviceOrderItems ServiceOrderItem[]
}

// === SERVICE ORDER APPROVAL (Workshop redesign Sub-fase A) ===
// Aprobación del cliente (o registro interno) para trabajo extra propuesto
// post-diagnóstico. `itemsJson` es snapshot; al aprobarse se crean los
// ServiceOrderItem reales con isExtra=true en el endpoint /respond.
model ServiceOrderApproval {
  id              String                       @id @default(uuid())
  serviceOrderId  String
  itemsJson       Json // [{ nombre, cantidad, precio, subtotal }]
  totalEstimado   Decimal                      @db.Decimal(10, 2)
  status          ServiceOrderApprovalStatus   @default(PENDING)
  channel         ServiceOrderApprovalChannel? // null mientras status = PENDING
  requestedAt     DateTime                     @default(now())
  // expiresAt = requestedAt + 48h (aplicado en código al crear). Backfill
  // de la migración usa el mismo cálculo. Lazy expiry corre en handlers
  // de respond y al renderizar la ficha técnica (P13-D.2).
  expiresAt       DateTime
  respondedAt     DateTime?
  respondedNote   String?
  createdByUserId String

  serviceOrder ServiceOrder @relation(fields: [serviceOrderId], references: [id], onDelete: Cascade)
  createdBy    User         @relation(fields: [createdByUserId], references: [id])

  @@index([serviceOrderId, status])
  @@index([status, requestedAt])
  @@index([status, expiresAt])
}

// === VOLTAGE CHANGE LOG ===
enum VoltageChangeReason {
  PRE_SALE
  POST_SALE
}

model VoltageChangeLog {
  id             String              @id @default(cuid())
  customerBikeId String
  fromVoltage    String
  toVoltage      String
  reason         VoltageChangeReason
  saleId         String?
  serviceOrderId String?
  userId         String
  createdAt      DateTime            @default(now())

  customerBike CustomerBike @relation(fields: [customerBikeId], references: [id])

  installedBatteries BatteryAssignment[] @relation("InstalledBatteries")
  removedBatteries   BatteryAssignment[] @relation("RemovedBatteries")
}

// === BATTERIES & ASSEMBLY ===
enum BatteryStatus {
  IN_STOCK
  INSTALLED
  DEFECTIVE
  WARRANTY_REVIEW
  IN_TRANSIT
}

enum AssemblyStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model BatteryConfiguration {
  id               String @id @default(cuid())
  modeloId         String
  voltajeId        String
  batteryVariantId String @map("batteryProductId")
  quantity         Int

  modelo         Modelo          @relation(fields: [modeloId], references: [id])
  voltaje        Voltaje         @relation(fields: [voltajeId], references: [id])
  batteryVariant ProductVariant  @relation("ConfiguredBattery", fields: [batteryVariantId], references: [id])
  assemblyOrders AssemblyOrder[]

  @@unique([modeloId, voltajeId, batteryVariantId])
}

model BatteryLot {
  id                String   @id @default(cuid())
  productVariantId  String?  @map("productId")
  simpleProductId   String?
  branchId          String
  supplier          String? // LEGACY string — Pack D.bis cutover dropea en C.7
  supplierId        String? // FK a Supplier — Pack D.bis
  reference         String?
  receivedAt        DateTime @default(now())
  userId            String
  saleItemId        String?
  purchaseReceiptId String?

  productVariant   ProductVariant?  @relation(fields: [productVariantId], references: [id])
  simpleProduct    SimpleProduct?   @relation(fields: [simpleProductId], references: [id])
  branch           Branch           @relation(fields: [branchId], references: [id])
  user             User             @relation(fields: [userId], references: [id])
  saleItem         SaleItem?        @relation(fields: [saleItemId], references: [id])
  purchaseReceipt  PurchaseReceipt? @relation(fields: [purchaseReceiptId], references: [id])
  supplierRelation Supplier?        @relation(fields: [supplierId], references: [id])
  batteries        Battery[]

  @@index([supplierId])
}

model Battery {
  id              String        @id @default(cuid())
  serialNumber    String        @unique
  lotId           String
  branchId        String
  status          BatteryStatus @default(IN_STOCK)
  assemblyOrderId String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  lot                BatteryLot          @relation(fields: [lotId], references: [id])
  branch             Branch              @relation(fields: [branchId], references: [id])
  assemblyOrder      AssemblyOrder?      @relation("ReservedBatteries", fields: [assemblyOrderId], references: [id])
  assignments        BatteryAssignment[]
  stockTransferItems StockTransferItem[]

  @@index([assemblyOrderId])
}

model AssemblyOrder {
  id                     String         @id @default(cuid())
  customerBikeId         String?
  productVariantId       String?
  batteryConfigurationId String?
  branchId               String
  saleId                 String?
  status                 AssemblyStatus @default(PENDING)
  assembledByUserId      String?
  completedAt            DateTime?
  notes                  String?
  receiptReference       String?
  voltageChangeLogId     String?        @unique
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt

  customerBike         CustomerBike?         @relation(fields: [customerBikeId], references: [id])
  productVariant       ProductVariant?       @relation(fields: [productVariantId], references: [id])
  batteryConfiguration BatteryConfiguration? @relation(fields: [batteryConfigurationId], references: [id])
  branch               Branch                @relation(fields: [branchId], references: [id])
  sale                 Sale?                 @relation(fields: [saleId], references: [id])
  assembledBy          User?                 @relation("AssemblyOrders", fields: [assembledByUserId], references: [id])
  reservedBatteries    Battery[]             @relation("ReservedBatteries")
}

model BatteryAssignment {
  id                         String    @id @default(cuid())
  batteryId                  String
  customerBikeId             String
  assemblyOrderId            String?
  isCurrent                  Boolean   @default(true)
  assignedAt                 DateTime  @default(now())
  assignedByUserId           String
  installedAtVoltageChangeId String?
  unassignedAt               DateTime?
  unassignedByUserId         String?
  removedAtVoltageChangeId   String?
  notes                      String?

  battery                  Battery           @relation(fields: [batteryId], references: [id])
  customerBike             CustomerBike      @relation(fields: [customerBikeId], references: [id])
  assignedByUser           User              @relation("AssignedBy", fields: [assignedByUserId], references: [id])
  unassignedByUser         User?             @relation("UnassignedBy", fields: [unassignedByUserId], references: [id])
  installedAtVoltageChange VoltageChangeLog? @relation("InstalledBatteries", fields: [installedAtVoltageChangeId], references: [id])
  removedAtVoltageChange   VoltageChangeLog? @relation("RemovedBatteries", fields: [removedAtVoltageChangeId], references: [id])
}

// === QUOTATIONS (COTIZACIONES) ===

enum QuotationStatus {
  DRAFT
  EN_ESPERA_CLIENTE
  EN_ESPERA_FABRICA
  PAGADA
  FINALIZADA
  RECHAZADA
}

model Quotation {
  id    String @id @default(cuid())
  folio String // "LEO-COT-0001"

  branchId String
  branch   Branch @relation("QuotationBranch", fields: [branchId], references: [id])

  userId String
  user   User   @relation("QuotationCreator", fields: [userId], references: [id])

  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  // Snapshot para walk-ins sin cliente capturado
  anonymousCustomerName  String?
  anonymousCustomerPhone String?

  status     QuotationStatus @default(DRAFT)
  validUntil DateTime

  subtotal       Decimal @db.Decimal(12, 2)
  discountAmount Decimal @default(0) @db.Decimal(12, 2)
  total          Decimal @db.Decimal(12, 2)

  // Autorización de descuento fijo (requiere rol MANAGER+)
  discountAuthorizedById String?
  discountAuthorizedBy   User?   @relation("QuotationDiscountAuth", fields: [discountAuthorizedById], references: [id])

  internalNote String?

  // Token público para vista print/PDF (sin auth)
  publicShareToken String @unique @default(cuid())

  // Trazabilidad de conversión
  convertedToSaleId   String?   @unique
  convertedToSale     Sale?     @relation("QuotationConvertedSale", fields: [convertedToSaleId], references: [id])
  convertedAt         DateTime?
  convertedByUserId   String?
  convertedByUser     User?     @relation("QuotationConverter", fields: [convertedByUserId], references: [id])
  convertedInBranchId String?
  convertedInBranch   Branch?   @relation("QuotationConvertedInBranch", fields: [convertedInBranchId], references: [id])

  cancelledAt       DateTime?
  cancelledByUserId String?
  cancelReason      String?

  items QuotationItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([branchId, folio])
  @@index([branchId, status])
  @@index([customerId])
  @@index([validUntil])
  @@map("cotizaciones")
}

model QuotationItem {
  id          String    @id @default(cuid())
  quotationId String
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  // Nullable para líneas libres ("instalación especial", "accesorio bajo pedido")
  productVariantId String?
  productVariant   ProductVariant? @relation(fields: [productVariantId], references: [id])

  // Catálogo: snapshot del nombre al cotizar. Línea libre: descripción manual.
  description String

  quantity  Int
  unitPrice Decimal @db.Decimal(12, 2) // precio congelado
  lineTotal Decimal @db.Decimal(12, 2)

  isFreeForm Boolean @default(false)

  createdAt DateTime @default(now())

  @@index([quotationId])
  @@map("cotizacion_items")
}

// === SIMPLE PRODUCTS (accesorios, cargadores, refacciones, baterías standalone) ===
// Nota: Stock, InventoryMovement y BatteryLot son polimórficos (productVariantId XOR simpleProductId).
// Los CHECK constraints y los índices únicos parciales viven en el SQL de la migración, no en Prisma.
// Ver AGENTS.md → Decisiones arquitectónicas clave.

enum SimpleProductCategoria {
  ACCESORIO
  CARGADOR
  REFACCION
  BATERIA_STANDALONE
}

model SimpleProduct {
  id              String                 @id @default(cuid())
  codigo          String                 @unique
  nombre          String
  descripcion     String?
  categoria       SimpleProductCategoria
  modeloAplicable String? // null = GLOBAL. Helper de normalización pendiente en P3.
  precioPublico   Decimal                @db.Decimal(10, 2)
  precioMayorista Decimal                @db.Decimal(10, 2)
  stockMinimo     Int                    @default(0)
  stockMaximo     Int                    @default(0)
  imageUrl        String?
  isActive        Boolean                @default(true)
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt

  stocks             Stock[]
  inventoryMovements InventoryMovement[]
  batteryLots        BatteryLot[]
  saleItems          SaleItem[]
  serviceOrderItems  ServiceOrderItem[]
  stockTransferItems StockTransferItem[]

  @@index([categoria, isActive])
  @@index([modeloAplicable])
}

// === SUPPLIERS (Pack D.bis) ===
//
// Consolidación de 3 strings dispersos:
// - PurchaseReceipt.proveedor (LEGACY, drop en C.7)
// - BatteryLot.supplier (LEGACY, drop en C.7)
// - CashTransaction.beneficiary (KEEP — sirve para destinatarios no-supplier)
//
// Sin enum de tipo: naturaleza emergente (ej. CFE puede aparecer en
// PurchaseReceipt para capacitación facturada). Filtrar por uso real
// (EXISTS join) en queries.
model Supplier {
  id        String   @id @default(uuid())
  nombre    String
  rfc       String?
  contacto  String?
  telefono  String?
  email     String?
  direccion String?
  notas     String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  purchaseReceipts PurchaseReceipt[]
  batteryLots      BatteryLot[]
  cashTransactions CashTransaction[]

  @@index([nombre])
  @@index([isActive])
}

// === PURCHASE RECEIPTS (Fase P4) ===
enum FormaPagoProveedor {
  CONTADO
  CREDITO
  TRANSFERENCIA
}

enum EstadoPagoProveedor {
  PAGADA
  PENDIENTE
  CREDITO
}

model PurchaseReceipt {
  id                    String              @id @default(cuid())
  branchId              String
  userId                String
  proveedor             String // LEGACY string — Pack D.bis cutover dropea en C.7
  supplierId            String? // FK a Supplier — Pack D.bis. Nullable hasta C.7 cutover (NOT NULL post-backfill).
  folioFacturaProveedor String?
  facturaUrl            String?
  formaPagoProveedor    FormaPagoProveedor
  estadoPago            EstadoPagoProveedor
  fechaVencimiento      String? // "YYYY-MM-DD" — fecha calendario sin tz
  fechaPago             DateTime?
  totalPagado           Decimal             @db.Decimal(12, 2)
  notas                 String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  branch             Branch              @relation(fields: [branchId], references: [id])
  user               User                @relation(fields: [userId], references: [id])
  supplier           Supplier?           @relation(fields: [supplierId], references: [id])
  inventoryMovements InventoryMovement[]
  batteryLots        BatteryLot[]

  @@unique([branchId, proveedor, folioFacturaProveedor])
  @@index([branchId, estadoPago])
  @@index([fechaVencimiento])
  @@index([supplierId])
}

// === AUTHORIZATIONS (Fase P5) ===
enum AuthorizationType {
  CANCELACION
  DESCUENTO
  CIERRE_DIFERENCIA // Autorización para cerrar corte con diferencia != 0 (solo SELLER — MANAGER/ADMIN cierran diferencias sin autorización)
}

enum AuthorizationStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED // solicitudes remotas con timeout (ver AuthorizationRequest.expiresAt)
}

enum AuthorizationMode {
  PRESENCIAL // manager teclea PIN en el mismo POS
  REMOTA // solicitud enviada al dashboard de otro manager
}

model AuthorizationRequest {
  id            String              @id @default(cuid())
  branchId      String
  tipo          AuthorizationType
  status        AuthorizationStatus @default(PENDING)
  mode          AuthorizationMode
  saleId        String? // CANCELACION: venta afectada. DESCUENTO: null hasta consumirse en una venta (marker de consumo).
  cashSessionId String?             @unique // CIERRE_DIFERENCIA: null hasta consumirse en el cierre de sesión (marker de consumo, @unique previene reuso).
  requestedBy   String
  approvedBy    String?
  monto         Decimal?            @db.Decimal(10, 2) // DESCUENTO: monto solicitado. CIERRE_DIFERENCIA: valor absoluto de la diferencia.
  motivo        String?             @db.Text
  rejectReason  String?             @db.Text
  expiresAt     DateTime? // null = sin expiración (PRESENCIAL). REMOTA: createdAt + 5min
  createdAt     DateTime            @default(now())
  resolvedAt    DateTime?

  branch      Branch               @relation(fields: [branchId], references: [id])
  sale        Sale?                @relation(fields: [saleId], references: [id])
  cashSession CashRegisterSession? @relation("SessionCloseAuth", fields: [cashSessionId], references: [id])
  requester   User                 @relation("AuthRequester", fields: [requestedBy], references: [id])
  approver    User?                @relation("AuthApprover", fields: [approvedBy], references: [id])

  @@index([branchId, status])
  @@index([requestedBy, status])
  @@index([saleId])
}

// === TESORERÍA (Fase P9) ===
enum ExpenseCategory {
  RENTA
  SERVICIOS
  NOMINA
  PUBLICIDAD
  TRANSPORTE
  MANTENIMIENTO_INMUEBLE
  IMPUESTOS
  COMISIONES_BANCARIAS
  OTRO
}

model OperationalExpense {
  id              String          @id @default(cuid())
  branchId        String
  branch          Branch          @relation(fields: [branchId], references: [id])
  categoria       ExpenseCategory
  descripcion     String
  monto           Decimal         @db.Decimal(12, 2)
  fecha           DateTime
  metodoPago      PaymentMethod // EXCLUIR CASH en validación Zod; los CASH viven en CashTransaction
  comprobanteUrl  String?
  registradoPor   String
  registradoBy    User            @relation("OperationalExpenseRegistradoPor", fields: [registradoPor], references: [id])
  isAnulado       Boolean         @default(false)
  anuladoPor      String?
  anuladoBy       User?           @relation("OperationalExpenseAnuladoPor", fields: [anuladoPor], references: [id])
  anuladoAt       DateTime?
  motivoAnulacion String?
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([branchId, fecha])
  @@index([branchId, categoria])
  @@index([isAnulado])
}

model BankBalanceSnapshot {
  id            String   @id @default(cuid())
  monto         Decimal  @db.Decimal(14, 2)
  notas         String?
  registradoPor String
  registradoBy  User     @relation("BankBalanceSnapshotRegistradoPor", fields: [registradoPor], references: [id])
  createdAt     DateTime @default(now())

  @@index([createdAt])
}

// === TRANSFERENCIAS ENTRE SUCURSALES (Fase P12) ===
enum StockTransferStatus {
  SOLICITADA
  BORRADOR
  EN_TRANSITO
  RECIBIDA
  CANCELADA
}

model StockTransfer {
  id           String              @id @default(cuid())
  folio        String              @unique
  fromBranchId String
  toBranchId   String
  status       StockTransferStatus @default(BORRADOR)

  creadoPor         String
  autorizadoPor     String?
  autorizadoAt      DateTime?
  despachadoPor     String?
  despachadoAt      DateTime?
  recibidoPor       String?
  recibidoAt        DateTime?
  canceladoPor      String?
  canceladoAt       DateTime?
  motivoCancelacion String?

  notas String?
  items StockTransferItem[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fromBranch        Branch @relation("TransferenciasSalientes", fields: [fromBranchId], references: [id])
  toBranch          Branch @relation("TransferenciasEntrantes", fields: [toBranchId], references: [id])
  creadoPorUser     User   @relation("TransferCreada", fields: [creadoPor], references: [id])
  autorizadoPorUser User?  @relation("TransferAutorizada", fields: [autorizadoPor], references: [id])
  despachadoPorUser User?  @relation("TransferDespachada", fields: [despachadoPor], references: [id])
  recibidoPorUser   User?  @relation("TransferRecibida", fields: [recibidoPor], references: [id])
  canceladoPorUser  User?  @relation("TransferCancelada", fields: [canceladoPor], references: [id])

  @@index([fromBranchId, status])
  @@index([toBranchId, status])
  @@index([createdAt])
}

model StockTransferItem {
  id         String @id @default(cuid())
  transferId String

  productVariantId String?
  simpleProductId  String?
  batteryId        String?
  customerBikeId   String?

  cantidadEnviada  Int
  cantidadRecibida Int?

  transfer       StockTransfer   @relation(fields: [transferId], references: [id], onDelete: Cascade)
  productVariant ProductVariant? @relation(fields: [productVariantId], references: [id])
  simpleProduct  SimpleProduct?  @relation(fields: [simpleProductId], references: [id])
  battery        Battery?        @relation(fields: [batteryId], references: [id])
  customerBike   CustomerBike?   @relation(fields: [customerBikeId], references: [id])

  @@index([transferId])
  @@index([batteryId])
  @@index([customerBikeId])
}

// === REPORTS v1 ===

enum ThresholdComparator {
  LT // menor que
  LTE // menor o igual
  GT // mayor que
  GTE // mayor o igual
  EQ // igual
}

model AlertThreshold {
  id             String              @id @default(uuid())
  metricKey      String // alineado con ALERT_METRICS en src/lib/reportes/alert-metrics.ts
  branchId       String
  branch         Branch              @relation(fields: [branchId], references: [id])
  thresholdValue Decimal             @db.Decimal(10, 2)
  comparator     ThresholdComparator
  isActive       Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([metricKey, branchId])
  @@index([branchId])
  @@index([metricKey])
}

// === WARRANTY POLICIES (Pack G.1 INT-4) ===

enum WarrantyPolicyStatus {
  ACTIVE
  EXPIRED
  VOID
}

model WarrantyPolicy {
  id                   String               @id @default(uuid())
  saleId               String
  saleItemId           String
  customerBikeId       String
  modeloId             String
  modeloCategoria      ModeloCategoria // SNAPSHOT al momento de venta
  warrantyDaysSnapshot Int // SNAPSHOT (Modelo.warrantyDays puede cambiar después)
  startedAt            DateTime
  expiresAt            DateTime // = startedAt + warrantyDaysSnapshot
  termsSnapshot        Json // SNAPSHOT del texto legal vigente al momento
  status               WarrantyPolicyStatus @default(ACTIVE)
  claimCount           Int                  @default(0)
  docPrintedAt         DateTime? // primera impresión
  lastPrintedAt        DateTime? // última reimpresión
  printCount           Int                  @default(0)
  docUrl               String? // R2 URL, set post-commit
  docSha256            String? // hash del PDF binary, set post-commit
  pdfEngineVersion     String?              @db.VarChar(64)
  alertSentAt120       DateTime? // centinela 1970-01-01 = silenciado backfill
  alertSentAt173       DateTime? // idem
  createdAt            DateTime             @default(now())

  sale         Sale         @relation(fields: [saleId], references: [id])
  saleItem     SaleItem     @relation(fields: [saleItemId], references: [id])
  customerBike CustomerBike @relation(fields: [customerBikeId], references: [id])
  modelo       Modelo       @relation(fields: [modeloId], references: [id])

  @@index([status, expiresAt])
  @@index([status, alertSentAt120])
  @@index([status, alertSentAt173])
}

// === WHATSAPP OUTBOX ===

enum OutboundMessageStatus {
  PENDING
  OPENED_IN_WAME
  EXPIRED
  CANCELLED
  ERROR
}

model WhatsAppTemplate {
  key               String   @id
  description       String
  bodyTemplate      String   @db.Text
  requiredVariables Json
  isActive          Boolean  @default(true)
  updatedAt         DateTime @updatedAt
  updatedByUserId   String?

  updatedByUser    User?             @relation("WaTemplateUpdatedBy", fields: [updatedByUserId], references: [id])
  outboundMessages OutboundMessage[]
}

model OutboundMessage {
  id             String                @id @default(uuid())
  templateKey    String
  customerId     String?
  recipientPhone String
  variables      Json
  renderedBody   String                @db.Text
  status         OutboundMessageStatus @default(PENDING)
  errorMessage   String?
  cancelReason   String?
  scheduledAt    DateTime              @default(now())
  expiresAt      DateTime?
  openedAt       DateTime?
  openedByUserId String?
  createdAt      DateTime              @default(now())

  template     WhatsAppTemplate @relation(fields: [templateKey], references: [key])
  customer     Customer?        @relation(fields: [customerId], references: [id])
  openedByUser User?            @relation("WaMessageOpenedBy", fields: [openedByUserId], references: [id])

  @@index([status, scheduledAt])
  @@index([customerId, status])
  @@index([status, expiresAt])
}
